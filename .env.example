# GovProcu MCP Server — 환경변수 템플릿
# 실제 .env는 .gitignore로 차단됨. 이 파일을 복사해서 사용:
#   cp .env.example .env

# === G2B (나라장터) API 키 ===
# 공공데이터포털에서 발급. 각 API별 일반 인증키(Encoding) 권장.
G2B_KEY_BID=
G2B_KEY_PRESPEC=
G2B_KEY_AWARD=
G2B_KEY_VENDOR=
G2B_KEY_USER=
G2B_KEY_STATS=

# === MCP 서버 인증 (사용자 토큰) ===
# 사내 사용자별 Bearer 토큰. 콤마로 구분.
MCP_API_TOKENS=dev-token-replace-me

# === Redis (캐시 + Rate Limit) ===
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SHORT=300
CACHE_TTL_LONG=86400

# === 운영 ===
LOG_LEVEL=INFO
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
