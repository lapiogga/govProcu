# GovProcu MCP Server — 환경변수 템플릿
# 실제 .env는 .gitignore로 차단됨. 이 파일을 복사해서 사용:
#   cp .env.example .env

# === G2B (나라장터) API 키 ===
# 공공데이터포털에서 발급. 각 API별 일반 인증키(Encoding) 권장.
G2B_KEY_BID=
G2B_KEY_PRESPEC=
G2B_KEY_AWARD=
G2B_KEY_CONTRACT=
G2B_KEY_USER=
G2B_KEY_STATS=
# 평가정보(기술/가격점수) 또는 응찰업체 상세 API 추가 신청 시 사용 (조달데이터허브)
G2B_KEY_EVAL=

# === 국세청 사업자등록 진위확인 및 상태조회 ===
# 발급처: https://www.data.go.kr → "국세청 사업자등록 진위확인" 검색 → 활용신청 (자동승인)
# Decoding 키 사용 권장. 호출당 최대 100개 사업자번호 일괄조회.
NTS_API_KEY=

# === 외부 발주기관 OpenAPI (data.go.kr — G2B와 동일 단일 인증키 재사용 가능) ===
# 활용신청 7종 (LH 5 + EX 1 + KWater 1):
#   https://www.data.go.kr/data/15021183/openapi.do  (LH 입찰공고)
#   https://www.data.go.kr/data/15042796/openapi.do  (LH 사전규격)
#   https://www.data.go.kr/data/15057180/openapi.do  (LH 개찰정보)
#   https://www.data.go.kr/data/15021184/openapi.do  (LH 계약현황)
#   https://www.data.go.kr/data/15042795/openapi.do  (LH 발주계획)
#   https://www.data.go.kr/data/15128076/openapi.do  (EX 계약공개)
#   https://www.data.go.kr/data/15101620/openapi.do  (KWater 계약공개)
LH_API_KEY=
EX_API_KEY=
KWATER_API_KEY=
# Korail은 data.go.kr에 입찰/계약 OpenAPI 미제공 — 자체 ebid.korail.com 별도

# === Gmail SMTP (이메일 알림 dispatcher) ===
# 발급: https://myaccount.google.com/apppasswords (2단계 인증 필수 선결)
# App Password 16자리 (공백 무시 가능). docs/USER-ACTIONS.md §2.1 참조.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=GovProcu Alert <noreply@your-domain>
SMTP_USE_TLS=true

# === MCP 서버 인증 (사용자 토큰) ===
# 사내 사용자별 Bearer 토큰. 콤마로 구분.
MCP_API_TOKENS=dev-token-replace-me

# === Redis (캐시 + Rate Limit) ===
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SHORT=300
CACHE_TTL_LONG=86400

# === 운영 ===
LOG_LEVEL=INFO
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
