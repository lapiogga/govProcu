# GovProcu MCP Server — 환경변수 템플릿
# 실제 .env는 .gitignore로 차단됨. 이 파일을 복사해서 사용:
#   cp .env.example .env

# === G2B (나라장터) API 키 ===
# 공공데이터포털에서 발급. 각 API별 일반 인증키(Encoding) 권장.
G2B_KEY_BID=
G2B_KEY_PRESPEC=
G2B_KEY_AWARD=
G2B_KEY_CONTRACT=
G2B_KEY_USER=
G2B_KEY_STATS=
# 평가정보(기술/가격점수) 또는 응찰업체 상세 API 추가 신청 시 사용 (조달데이터허브)
G2B_KEY_EVAL=

# === DART (전자공시) OPENDART API ===
# 발급처: https://opendart.fss.or.kr → 마이페이지 → 인증키 신청 (40자리)
# 일일 한도 20,000건. 상장사 + 외부감사 대상 법인만 등록되어 있음.
DART_API_KEY=

# === 국세청 사업자등록 진위확인 및 상태조회 ===
# 발급처: https://www.data.go.kr → "국세청 사업자등록 진위확인" 검색 → 활용신청 (자동승인)
# Decoding 키 사용 권장. 호출당 최대 100개 사업자번호 일괄조회.
NTS_API_KEY=

